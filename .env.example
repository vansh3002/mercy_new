# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Gmail Alerts ,sends you emails on key store events
# GMAIL_USER: your Gmail address used to send alerts
# GMAIL_APP_PASSWORD: 16-char App Password (not your login password)
#   Setup: Google Account → Security → 2-Step Verification → App passwords
# NOTIFY_EMAIL: where to receive alerts (can be same as GMAIL_USER)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
NOTIFY_EMAIL=you@gmail.com

# OTP Provider ,2Factor (https://2factor.in)
TWOFACTOR_API_KEY=your_2factor_api_key_here

# Data source: "mock" (no DB) or "db" (Prisma + PostgreSQL)
DATA_SOURCE=mock

# Shiprocket
SHIPROCKET_EMAIL=you@example.com
SHIPROCKET_PASSWORD=your_password
SHIPROCKET_PICKUP_LOCATION=Primary Warehouse
SHIPROCKET_DEFAULT_WEIGHT=0.5
SHIPROCKET_DEFAULT_LENGTH=10
SHIPROCKET_DEFAULT_BREADTH=10
SHIPROCKET_DEFAULT_HEIGHT=5

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
